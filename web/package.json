{
  "name": "flock-web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint:js": "eslint .",
    "lint:prettier": "prettier --check \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json}\"",
    "type-check": "tsc -b --noEmit",
    "lint": "npm run lint:js && npm run lint:prettier && npm run type-check",
    "lint:fix": "eslint . --fix && prettier --write \"src/**/*.{ts,tsx,css}\" \"*.{ts,js,json}\"",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "i18next": "^23.16.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-i18next": "^15.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.19.20",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "eslint": "^9.39.4",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.8.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.0",
    "vite": "^5.4.8",
    "vitest": "^2.1.4"
  }
}
