# Managed by Ansible — roles/claude_tg_bot/templates/env.j2  (rendered with secrets)
# === REQUIRED ===
TELEGRAM_BOT_TOKEN={{ vault_telegram_bot_token }}
TELEGRAM_BOT_USERNAME={{ telegram_bot_username }}
APPROVED_DIRECTORY={{ approved_directory }}
ALLOWED_USERS={{ vault_allowed_users }}

# === CLAUDE AUTH ===
USE_SDK=true
CLAUDE_MODEL={{ claude_model }}
{% if enable_dind %}
DOCKER_HOST=tcp://dind:2375
{% endif %}
{% if claude_auth_mode == 'subscription' %}
# Pro/Max subscription via `claude setup-token`. ANTHROPIC_API_KEY is intentionally
# omitted — if set, it would take precedence over the subscription token.
CLAUDE_CODE_OAUTH_TOKEN={{ vault_claude_oauth_token }}
{% else %}
# Pay-per-token Console API key.
ANTHROPIC_API_KEY={{ vault_anthropic_api_key }}
{% endif %}
CLAUDE_MAX_TURNS={{ claude_max_turns }}
CLAUDE_TIMEOUT_SECONDS={{ claude_timeout_seconds }}
CLAUDE_MAX_COST_PER_USER={{ claude_max_cost_per_user }}
CLAUDE_MAX_COST_PER_REQUEST={{ claude_max_cost_per_request }}

# === SECURITY ===
# Non-standard ENVIRONMENT (see defaults/main.yml) so the bot honors the limits above
# instead of its hardcoded production caps. Whitelist stays ON: it depends on
# debug + development_mode being false, not on this string.
ENVIRONMENT={{ bot_environment }}
DEVELOPMENT_MODE=false
DEBUG=false
DISABLE_SECURITY_PATTERNS=false
DISABLE_TOOL_VALIDATION=false

# === RATE LIMITING ===
RATE_LIMIT_REQUESTS={{ rate_limit_requests }}
RATE_LIMIT_WINDOW={{ rate_limit_window }}

# How many chats may run IN PARALLEL (each chat is still serial within itself). Caps memory
# on a small host — raise with RAM headroom, set 1 to fully serialize like before.
MAX_CONCURRENT_CHAT_RUNS={{ max_concurrent_chat_runs | default(4) }}
# Dev-team loop limits — the image renders these into the workspace CLAUDE.md on start.
PRE_PR_CYCLES={{ pre_pr_cycles }}
PR_REVIEW_CYCLES={{ pr_review_cycles }}
# Group chats: false (default) = answer every message; true = only on @mention/reply.
REQUIRE_GROUP_MENTION={{ require_group_mention | default(false) | string | lower }}
# Published-PR review/fix loop (poller + CLAUDE.md Phase 2). false (default) = off:
# build + open a PR, then stop; no on-PR review or comment reactions.
ENABLE_PR_REVIEW={{ enable_pr_review | default(false) | string | lower }}
# Bot API 10.1 rich messages (structured blocks + native rich draft). false (default) = off:
# legacy Markdown→HTML rendering; true = render rich (Telegram only, falls back on any error).
ENABLE_RICH_MESSAGES={{ enable_rich_messages | default(false) | string | lower }}
{% if webhook_domain %}

# === WEBHOOK SERVER (PR monitoring) ===
ENABLE_API_SERVER=true
API_SERVER_PORT=8080
WEBHOOK_API_SECRET={{ vault_webhook_secret }}
NOTIFICATION_CHAT_IDS={{ notification_chat_ids }}
{% endif %}

{% if vault_mistral_api_key is defined and vault_mistral_api_key %}
# === VOICE (transcription via Mistral Voxtral) ===
ENABLE_VOICE_MESSAGES=true
VOICE_PROVIDER=mistral
MISTRAL_API_KEY={{ vault_mistral_api_key }}
{% endif %}

# === STORAGE ===
DATABASE_URL=sqlite:///data/bot.db
SESSION_TIMEOUT_HOURS=24

# === MISC ===
LOG_LEVEL=INFO
ENABLE_TELEMETRY=false
{% if gitea_host is defined and gitea_host %}

# === GIT — entrypoint git config + credential helper + the PR poller ===
GIT_HOST={{ gitea_host }}
GIT_SCHEME={{ gitea_scheme }}
GIT_USER={{ gitea_user }}
GIT_TOKEN={{ vault_gitea_token }}
# Also expose as GH_TOKEN so the `gh` CLI is authenticated — used to open PRs on github.com.
GH_TOKEN={{ vault_gitea_token }}
GIT_AUTHOR_NAME={{ git_user_name }}
GIT_AUTHOR_EMAIL={{ git_user_email }}
# PR poller — reaches PR comments without inbound webhooks. GITEA_POLL_INTERVAL=0 disables.
GITEA_API_URL={{ gitea_scheme }}://{{ gitea_host }}/api/v1
GITEA_POLL_INTERVAL={{ gitea_poll_interval | default(90) }}
{% endif %}
