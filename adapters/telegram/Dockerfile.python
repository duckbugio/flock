# Self-contained image for the DuckFlock AI dev-team Telegram bot.
# Everything is baked in; behaviour is toggled at RUNTIME via env (see .env.example).
# Built & published by .github/workflows/publish-telegram.yml -> ghcr.io/duckbugio/flock-telegram
# Build context is the REPO ROOT (COPY paths are root-relative): docker build -f adapters/telegram/Dockerfile .
FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONUNBUFFERED=1 \
    NODE_MAJOR=22 \
    BOT_VERSION=v1.6.0

# System deps: Node (the `claude` CLI), git/gh/ripgrep, ffmpeg (voice), gettext (envsubst),
# Docker CLI (talks to the optional dind sidecar). All unconditional — toggled by env.
RUN set -eux; \
    apt-get update; \
    apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg git ripgrep ffmpeg gettext-base; \
    install -m 0755 -d /etc/apt/keyrings; \
    curl -fsSL https://deb.nodesource.com/setup_${NODE_MAJOR}.x | bash -; \
    apt-get install -y --no-install-recommends nodejs; \
    curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg -o /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    chmod 0644 /etc/apt/keyrings/githubcli-archive-keyring.gpg; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list; \
    curl -fsSL https://download.docker.com/linux/debian/gpg -o /etc/apt/keyrings/docker.asc; \
    chmod a+r /etc/apt/keyrings/docker.asc; \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/debian $(. /etc/os-release && echo $VERSION_CODENAME) stable" > /etc/apt/sources.list.d/docker.list; \
    apt-get update; \
    apt-get install -y --no-install-recommends gh docker-ce-cli docker-compose-plugin; \
    npm install -g @anthropic-ai/claude-code; \
    npm cache clean --force; \
    apt-get clean; rm -rf /var/lib/apt/lists/*

# Non-root runtime user; pre-create writable dirs so named volumes inherit uid 1000.
RUN useradd -m -u 1000 -s /bin/bash claude \
 && mkdir -p /workspace /app/data /home/claude/.claude /opt/duck/agents \
 && chown -R claude:claude /workspace /app /home/claude/.claude /opt/duck

# Git credential helper: emits GIT_USER/GIT_TOKEN at runtime (host wired by the entrypoint).
RUN printf '#!/bin/sh\n[ "$1" = "get" ] || exit 0\necho "username=${GIT_USER}"\necho "password=${GIT_TOKEN}"\n' \
        > /usr/local/bin/git-credential-gitea \
 && chmod 0755 /usr/local/bin/git-credential-gitea

# Entrypoint (root path) — wires git + renders the team config into the workspace.
COPY adapters/telegram/entrypoint.sh /usr/local/bin/entrypoint.sh
RUN chmod 0755 /usr/local/bin/entrypoint.sh

USER claude
ENV HOME=/home/claude \
    PATH=/home/claude/.local/bin:$PATH

# The bot WITH its voice extra. Use the extra (not bare `mistralai`) — the bot pins
# mistralai>=1,<2, but a bare install grabs 2.x whose `from mistralai import Mistral` breaks.
RUN pip install --user "claude-code-telegram[voice] @ git+https://github.com/RichardAtCT/claude-code-telegram@${BOT_VERSION}"

# Bake the feature patches and apply them to the installed package.
COPY --chown=claude:claude adapters/telegram/patches/*.py /home/claude/patch/
RUN python3 /home/claude/patch/patch_chat_scope.py /home/claude/patch/chat_scope.py \
 && python3 /home/claude/patch/patch_persistence.py \
 && python3 /home/claude/patch/patch_mention_gate.py /home/claude/patch/mention_gate.py \
 && python3 /home/claude/patch/patch_auth_welcome.py \
 && python3 /home/claude/patch/patch_webhook.py /home/claude/patch/webhook_responder.py \
 && python3 /home/claude/patch/patch_webhook_routing.py \
 && python3 /home/claude/patch/patch_gitea_poller.py /home/claude/patch/gitea_poller.py \
 && python3 /home/claude/patch/patch_chat_queue.py /home/claude/patch/chat_queue.py \
 && python3 /home/claude/patch/patch_session_timeout.py \
 && python3 /home/claude/patch/patch_working_counter.py

# Shared team config — the entrypoint renders these into the workspace on start.
COPY --chown=claude:claude core/agents/*.md /opt/duck/agents/
COPY --chown=claude:claude core/CLAUDE.workspace.md.tmpl /opt/duck/CLAUDE.workspace.md.tmpl

WORKDIR /app
ENTRYPOINT ["/usr/local/bin/entrypoint.sh"]
CMD ["claude-telegram-bot"]
